!data/**/.gitkeep
*.json
!config/*.json

# Notebooks checkpoints
.ipynb_checkpoints/

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
logs/
*.log

# ChromaDB persisted store
chroma_db/

# Pytest cache
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/
