# ── Anthropic / Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── News APIs (pick one or more) ────────────────────────────────────────────
# NewsAPI.org — free tier: 100 requests/day
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage — free tier: 25 requests/day (fundamentals + news sentiment)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Vector DB ────────────────────────────────────────────────────────────────
# ChromaDB runs locally by default — no key needed for local mode.
# Set this only if using Chroma Cloud.
CHROMA_API_KEY=

# ── App settings ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# Default universe
STOCK_UNIVERSE=NIFTY50
