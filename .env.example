# EquityLens — environment configuration
# Copy this file to .env and fill in your keys.
# Only GROQ_API_KEY is required (free). Everything else has safe defaults.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "groq"   → free, no credit card (recommended)
# "claude" → best quality, requires Anthropic credits
LLM_PROVIDER=groq

# ── Groq (free — sign up at console.groq.com) ────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic / Claude (only needed if LLM_PROVIDER=claude) ──────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── News APIs (optional — leave blank to use free RSS feeds) ─────────────────
# NewsAPI.org free tier: 100 req/day  →  https://newsapi.org/register
NEWS_API_KEY=
# Alpha Vantage free tier: 25 req/day  →  https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── Embedding model (runs locally, no key needed) ────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# ── RAG retrieval ─────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8

# ── Storage paths ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=equity_research
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
STOCK_UNIVERSE=NIFTY50
